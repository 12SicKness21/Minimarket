rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Solo admin autenticado puede escribir
    match /productos/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /combos/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // La app envía pedidos por WhatsApp — no se escribe en Firestore desde el cliente.
    // Se bloquea toda escritura pública para eliminar la brecha de price tampering.
    match /pedidos/{id} {
      allow read, write: if request.auth != null;
    }
    match /configuracion/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
